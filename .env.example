# Environment Configuration Template
# Copy this file to .env and fill in your values

# Application
DEBUG=false
ENVIRONMENT=development
APP_NAME="Brain Tumor AI Framework"
APP_VERSION="1.0.0"

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# FalkorDB Graph Database
FALKORDB_HOST=falkordb
FALKORDB_PORT=6379

# Redis & Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Storage (MinIO)
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_DICOM=dicom-scans
MINIO_BUCKET_RESULTS=segmentation-results

# Storage (AWS S3) - Alternative to MinIO
# STORAGE_BACKEND=s3
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET_DICOM=brain-tumor-dicom
# AWS_S3_BUCKET_RESULTS=brain-tumor-results

# ML Models (2D ensemble)
MODEL_2D_PATH=/models/brain_tumor_2d.pth
MODEL_RESNET50_PATH=/models/brain_tumor_resnet50.pth
MODEL_EFFICIENTNET_PATH=/models/brain_tumor_efficientnet.pth
MODEL_DENSENET_PATH=/models/brain_tumor_densenet.pth
DEVICE=cuda  # 'cuda' or 'cpu'
INFERENCE_BATCH_SIZE=1
NUM_INFERENCE_WORKERS=4

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload
MAX_FILE_SIZE_MB=500
ALLOWED_EXTENSIONS=dcm,nii,nii.gz
CHUNK_SIZE_BYTES=1048576  # 1MB

# Frontend
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_WS_URL=ws://localhost:8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Task Configuration
CELERY_TASK_TIME_LIMIT=3600  # 1 hour
CELERY_TASK_SOFT_TIME_LIMIT=3300  # 55 minutes

# CUDA (GPU)
CUDA_VISIBLE_DEVICES=0

# Ensemble model selection (comma-separated)
ENSEMBLE_MODELS=custom_cnn,resnet50,efficientnet,densenet

# Kaggle (optional, for automatic multi-dataset download)
# Option 1: env credentials
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key
#
# Option 2: mount kaggle.json from host
# Put kaggle.json at ./.kaggle/kaggle.json (not committed)
KAGGLE_CONFIG_DIR=/root/.kaggle
KAGGLE_VOLUME_PATH=./.kaggle
